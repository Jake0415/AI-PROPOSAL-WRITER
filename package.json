{
  "name": "aiprowriter",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:unit": "vitest run --dir lib",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "db:seed": "tsx scripts/seed.ts",
    "dev:db": "docker compose up db -d",
    "dev:seed": "tsx scripts/seed.ts",
    "verify": "tsc --noEmit && npm run lint && npm run test && npm run test:e2e",
    "deploy": "docker compose up -d --build",
    "deploy:clean": "docker compose down -v && docker compose up -d --build",
    "deploy:init": "docker compose run --rm init",
    "deploy:verify": "PLAYWRIGHT_BASE_URL=http://localhost:3100 npm run test:e2e"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.79.0",
    "@opendataloader/pdf": "^2.0.2",
    "@qdrant/js-client-rest": "^1.17.0",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-navigation-menu": "^1.2.14",
    "@radix-ui/react-slot": "^1.2.3",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "docx": "^9.6.1",
    "docxtemplater": "^3.68.3",
    "dotenv": "^17.3.1",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.1",
    "jose": "^6.2.1",
    "lucide-react": "^0.543.0",
    "mammoth": "^1.12.0",
    "mermaid": "^11.13.0",
    "next": "^16.1.7",
    "next-themes": "^0.4.6",
    "openai": "^6.32.0",
    "pdf-parse": "^2.4.5",
    "pizzip": "^3.2.0",
    "postcss": "^8.5.6",
    "postgres": "^3.4.8",
    "pptxgenjs": "^4.0.1",
    "radix-ui": "^1.4.3",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.3.1",
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4.1.13",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/pdf-parse": "^1.1.5",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9",
    "eslint-config-next": "^16.1.7",
    "jsdom": "^29.0.0",
    "playwright": "^1.58.2",
    "tailwindcss": "^4.1.13",
    "tw-animate-css": "^1.3.8",
    "typescript": "^5",
    "vitest": "^4.1.0"
  }
}
