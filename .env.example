# Next.js 환경변수 예제 파일
# 이 파일을 .env.local로 복사한 후 실제 값을 입력하세요

# 스킬 참조  정보 : claude에서 경로 넣고 주기적으로 필요 사항 적용
# CLAUDE_SKILL_REFERENCE="https://github.com/affaan-m/everything-claude-code/tree/main/rules"
# AWESOME_SKILL_REFERENCE="https://github.com/ComposioHQ/awesome-claude-skills"


# 애플리케이션 설정
NEXT_PUBLIC_APP_NAME="AIPROWRITER"
NEXT_PUBLIC_APP_DESCRIPTION="RFP를 업로드하면 AI가 분석하여 완성된 제안서를 자동 생성합니다"

# ─── Supabase (필수) ────────────────────────────────────────
# Supabase 프로젝트 대시보드 → Settings → API에서 확인
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-supabase-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"

# Supabase Database (Drizzle ORM 직접 연결용)
# Supabase 대시보드 → Settings → Database → Connection string
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres"

# ─── AI (필수) ──────────────────────────────────────────────
ANTHROPIC_API_KEY="your-anthropic-api-key"

# ─── Slack API (선택) ───────────────────────────────────────
# SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
# SLACK_TEAM_ID=your-team-id
# SLACK_CHANNEL=your-channel-id
# SLACK_BOT_USER_ID=your-bot-user-id
# SLACK_TARGET_USER_ID=your-target-user-id

# ─── 배포 설정 (선택) ──────────────────────────────────────
# NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
