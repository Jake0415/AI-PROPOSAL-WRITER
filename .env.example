# Next.js 환경변수 예제 파일
# 이 파일을 .env.local로 복사한 후 실제 값을 입력하세요

# ─── 애플리케이션 설정 ──────────────────────────────────────
NEXT_PUBLIC_APP_NAME="AIPROWRITER"
NEXT_PUBLIC_APP_DESCRIPTION="RFP를 업로드하면 AI가 분석하여 완성된 제안서를 자동 생성합니다"

# ─── 인증 (필수) ──────────────────────────────────────────────
# JWT 서명 키 (32자 이상 랜덤 문자열, 예: openssl rand -base64 32)
JWT_SECRET="your-jwt-secret-change-this-to-random-string"

# ─── 데이터베이스 (필수) ──────────────────────────────────────
# Docker Compose 사용 시 자동으로 설정됨 (docker-compose.yml의 environment 참조)
# 로컬 개발 시 직접 설정:
DATABASE_URL="postgresql://aiprowriter:aiprowriter@localhost:5434/aiprowriter"
POSTGRES_PASSWORD="aiprowriter"

# ─── AI (필수) ──────────────────────────────────────────────
# 프로바이더 선택: "claude" | "gpt" (기본값: claude)
AI_PROVIDER="claude"

# Claude API
ANTHROPIC_API_KEY="your-anthropic-api-key"
# AI_MODEL_CLAUDE="claude-sonnet-4-6"

# OpenAI API
OPENAI_API_KEY="your-openai-api-key"
# AI_MODEL_GPT="gpt-4o"

# ─── Slack API (선택) ───────────────────────────────────────
# SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
# SLACK_TEAM_ID=your-team-id
# SLACK_CHANNEL=your-channel-id
# SLACK_BOT_USER_ID=your-bot-user-id
# SLACK_TARGET_USER_ID=your-target-user-id

# ─── 배포 설정 (선택) ──────────────────────────────────────
# NEXT_PUBLIC_APP_URL=https://your-app.example.com
