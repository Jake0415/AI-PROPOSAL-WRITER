{
  "permissions": {
    "allow": [
      "Bash",
      "Read",
      "Write",
      "Edit",
      "Glob",
      "Grep",
      "WebFetch",
      "WebSearch",
      "Agent",
      "TodoWrite",
      "NotebookEdit",
      "mcp__sequential-thinking",
      "mcp__shadcn",
      "mcp__shadcn__search_items_in_registries",
      "mcp__context7__resolve-library-id",
      "mcp__context7__get-library-docs",
      "mcp__context7__query-docs",
      "mcp__slack__slack_list_channels",
      "mcp__slack__slack_post_message",
      "mcp__slack__slack_get_channel_history",
      "mcp__slack__slack_get_thread_replies",
      "mcp__claude_ai_Gmail",
      "mcp__shrimp-task-manager"
    ],
    "deny": [
      "Bash(rm -rf /:*)",
      "Bash(git push --force origin main:*)",
      "Bash(git reset --hard:*)",
      "Bash(DROP DATABASE:*)"
    ],
    "ask": [
      "Bash(npm install:*)",
      "Bash(npm add:*)",
      "Bash(pip install:*)",
      "Bash(apt install:*)",
      "Bash(brew install:*)",
      "Bash(npx shadcn:*)"
    ]
  },
  "enableAllProjectMcpServers": true,
  "hooks": {
    "postToolUse": [
      {
        "matcher": "Edit|Write",
        "command": "npx tsc --noEmit --pretty 2>&1 | head -20"
      }
    ],
    "stop": [
      {
        "command": "echo '=== 검증 시작 ===' && echo '--- 타입 체크 ---' && npx tsc --noEmit 2>&1 | tail -3 && echo '--- E2E 테스트 ---' && PLAYWRIGHT_BASE_URL=http://localhost:3100 npx playwright test --reporter=list 2>&1 | tail -15 && echo '=== 검증 완료 ==='"
      }
    ],
    "Notification": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/notification-hook.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/stop-hook.sh"
          }
        ]
      }
    ]
  }
}
