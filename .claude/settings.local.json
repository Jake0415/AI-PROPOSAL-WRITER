      "mcp__shrimp-task-manager__init_project_rules",
      "mcp__shrimp-task-manager__list_tasks",
      "mcp__shrimp-task-manager__plan_task",
      "mcp__shrimp-task-manager__process_thought",
      "mcp__shrimp-task-manager__query_task",
      "mcp__shrimp-task-manager__reflect_task",
      "mcp__shrimp-task-manager__research_mode",
      "mcp__shrimp-task-manager__split_tasks",
      "mcp__shrimp-task-manager__update_task",
      "mcp__shrimp-task-manager__verify_task",
      "Bash(grep -r \"ANTHROPIC_API_KEY\\\\|@anthropic-ai/sdk\" /c/claude-code/AI-PROPOSAL-WRITER/lib --include=*.ts --include=*.tsx)",
      "Bash(node -e \":*)",
      "Bash(find /c/claude-code/AI-PROPOSAL-WRITER/app/api -type f -name *.ts)",
      "Bash(npm test:*)",
      "Bash(curl -s http://localhost:3004/auth/login)",
      "Bash(curl -s http://localhost:3004/api/projects)",
      "Bash(curl -s http://localhost:3004/api/settings/ai)",
      "Bash(curl -s http://localhost:3004/api/admin/stats)",
      "Bash(curl -s http://localhost:3004/api/templates)",
      "Bash(/dev/null echo:*)",
      "Bash(head -c 80 echo \"\" echo \"\" __NEW_LINE_6677f3d95cd2a361__ echo \"4. Supabase Auth\" echo \"  회원가입: 성공 \\(test@aiprowriter.com\\)\" echo \"  이메일 확인: 완료\" echo \"  로그인: 성공 \\(토큰 발급\\)\" echo \"\" __NEW_LINE_6677f3d95cd2a361__ echo \"5. DB 연결 \\(Supabase PostgreSQL\\)\" echo \"  스키마: aiprowriter \\(10개 테이블\\)\")"
    ],
    "deny": [
      "Bash(rm:*)",
      "Bash(git reset:*)",
      "Bash(git push --force:*)"
    ],
    "ask": []
  },
  "enableAllProjectMcpServers": true,
  "hooks": {
    "postToolUse": [
      {
        "matcher": "Edit|Write",
        "command": "npx tsc --noEmit --pretty 2>&1 | head -20"
      }
    ],
    "stop": [
      {
        "command": "echo '--- 품질 확인 ---' && npx tsc --noEmit 2>&1 | tail -5 && echo '---' && grep -rn 'console\\.log' --include='*.ts' --include='*.tsx' app/ components/ lib/ 2>/dev/null | head -5 && echo '확인 완료'"
      }
    ],
    "Notification": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/notification-hook.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/stop-hook.sh"
          }
        ]
      }
    ]
  }
}
